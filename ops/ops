def _render_cmdb(s: dict) -> str:
    cmdb = s["cmdb"]
    by_owner: dict[str, list[tuple[str, dict]]] = defaultdict(list)
    for cid, c in cmdb.items():
        by_owner[c.get("owner_agent", "unknown")].append((cid, c))
    sections = []
    for owner in sorted(by_owner.keys()):
        rows = []
        for cid, c in sorted(by_owner[owner]):
            sens = '<span class="tag sens">sensitive</span>' if c.get("sensitive") else ""
            deps = ", ".join(c.get("depends_on") or []) or "—"
            rows.append(
                f'<tr><td><code>{_h(cid)}</code> {sens}</td>'
                f'<td>{_h(c.get("type",""))}</td>'
                f'<td>{_h(c.get("description",""))}</td>'
                f'<td class="num">{_h(deps)}</td>'
                '</tr>'
            )
        sections.append(
            f'<section><h2>{_h(owner)} '
            f'<span class="tag">{len(by_owner[owner])}</span></h2>'
            '<table><thead><tr><th>id</th><th>type</th><th>description</th>'
            '<th>depends_on</th></tr></thead>'
            f'<tbody>{"".join(rows)}</tbody></table></section>'
        )
    body = (
        f'<p class="meta">{len(cmdb)} components, grouped by owner agent.</p>'
        + "".join(sections)
    )
    return _page("CMDB", "cmdb.html", body, s["now"])


def _render_risks(s: dict) -> str:
    risks = s["risks"]
    if not risks:
        body = '<section><p class="empty">no accepted risks on file</p></section>'
        return _page("Accepted risks", "risks.html", body, s["now"])
    rows = []
    for r in sorted(risks, key=lambda x: x.get("id", "")):
        adr = r.get("adr", "")
        adr_link = (f'<a href="https://github.com/vdhict/vdhinfra/blob/main/{_h(adr)}">'
                    f'{_h(adr)}</a>') if adr else "—"
        rows.append(
            f'<tr><td><code>{_h(r.get("id",""))}</code></td>'
            f'<td>{_h(r.get("finding_title",""))}</td>'
            f'<td>{_h(r.get("rationale",""))}</td>'
            f'<td>{adr_link}</td>'
            f'<td class="ts">{_h(r.get("accepted_by",""))}<br>'
            f'<small>{_h(r.get("accepted_at",""))} → review {_h(r.get("review_by",""))}</small></td>'
            '</tr>'
        )
    body = (
        '<section><h2>Accepted risks '
        f'<span class="tag">{len(risks)}</span></h2>'
        '<table><thead><tr><th>id</th><th>finding</th><th>rationale</th>'
        '<th>ADR</th><th>by / dates</th></tr></thead>'
        f'<tbody>{"".join(rows)}</tbody></table></section>'
    )
    return _page("Accepted risks", "risks.html", body, s["now"])


