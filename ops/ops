_TIER_LABELS = {
    0: "Internet",
    1: "Edge",
    2: "Cluster",
    3: "Stateful",
    4: "Services",
    5: "Family services",
}

# Fallback tier inference for entries that don't carry tier: yet.
# Apollo flags this in the rendered page so it's not silent.
def _infer_tier(cid: str, comp: dict) -> int:
    t = comp.get("tier")
    if isinstance(t, int):
        return t
    if isinstance(t, str) and t.strip().lstrip("-").isdigit():
        return int(t.strip())
    typ = (comp.get("type") or "").lower()
    owner = (comp.get("owner_agent") or "").lower()
    if typ == "external-service" and "cloudflare" in cid:
        return 0
    if typ == "external-service":
        return 0
    if cid.startswith("net.") or typ in ("network-device", "network-config", "power-device"):
        return 1
    if typ == "k8s-cluster":
        return 2
    if cid.startswith("k8s.") and typ == "k8s-app":
        # gateway/cni/storage/etc. are cluster substrate
        if any(k in cid for k in (".cni", ".storage", ".gitops", ".secrets", ".gateway")):
            return 2
        return 4
    if cid.startswith("db.") or cid.startswith("backup.") or cid.startswith("storage."):
        return 3
    if cid.startswith("obs.") or cid.startswith("auth."):
        return 4
    if cid.startswith("ha.") or cid.startswith("media."):
        return 4
    return 4


def _node_status(cid: str, live: dict) -> str:
    """Read live status for a CMDB id from the merged (unifi+k8s) state map."""
    v = (live.get(cid) or {}).get("status")
    if v in ("ok", "warning", "down", "unknown"):
        return v
    return "unknown"


def _merged_live(cmdb: dict) -> dict:
    """Merge UniFi-topology and k8s-status live state into one map keyed by
    CMDB id. k8s wins where both fire."""
    merged: dict = dict(_load_unifi_topology() or {})
    merged.update(_load_k8s_status(cmdb) or {})
    return merged


def _has_graphviz() -> bool:
    """Return True if `dot` is on PATH."""
    import shutil
    return shutil.which("dot") is not None


def _topology_tiers(s: dict) -> dict[int, list[tuple[str, dict]]]:
    """Group CMDB entries by tier (0..5)."""
    cmdb = s.get("cmdb") or {}
    by_tier: dict[int, list[tuple[str, dict]]] = defaultdict(list)
    for cid, comp in sorted(cmdb.items()):
        t = _infer_tier(cid, comp or {})
        # collapse anything >5 into 5
        t = max(0, min(5, t))
        by_tier[t].append((cid, comp or {}))
    return by_tier


def _render_topology_via_graphviz(s: dict) -> str:
    """Pipe a DOT description through `dot -Tsvg` and return inline SVG."""
    import subprocess
    cmdb = s.get("cmdb") or {}
    topo = _merged_live(cmdb)
    by_tier = _topology_tiers(s)

    def safe(cid: str) -> str:
        return "n_" + re.sub(r"[^a-zA-Z0-9]", "_", cid)

    lines = [
        'digraph topology {',
        '  rankdir=TB; bgcolor="transparent"; pad=0.2; nodesep=0.25; ranksep=0.45;',
        '  fontname="system-ui";',
        '  node [shape=box, style="rounded,filled", fontname="system-ui",'
        ' fontsize=11, color="#888", fillcolor="white"];',
        '  edge [color="#888", arrowsize=0.6, penwidth=0.9];',
    ]
    # subgraphs (clusters) per tier — rank=same keeps them on one row.
    for t in sorted(by_tier.keys()):
        members = by_tier[t]
        lines.append(f'  subgraph cluster_t{t} {{')
        lines.append(f'    label="{t} — {_TIER_LABELS.get(t, str(t))}";'
                     ' style="dashed"; color="#bbb"; fontsize=10; fontcolor="#888";')
        lines.append('    rank=same;')
        for cid, comp in members:
            st = _node_status(cid, topo)
            fill = {
                "ok": "#e8f7eb", "warning": "#fff5cf",
                "down": "#ffe5e0", "unknown": "white",
            }.get(st, "white")
            border = {
                "ok": "#2a9d3f", "warning": "#c08a00",
                "down": "#c0392b", "unknown": "#888",
            }.get(st, "#888")
            label = cid
            tooltip = (comp.get("description") or "")[:120].replace('"', "'")
            lines.append(
                f'    {safe(cid)} [label="{label}", '
                f'fillcolor="{fill}", color="{border}", '
                f'tooltip="{tooltip}", URL="cmdb.html#{cid}", target="_top"];'
            )
        lines.append('  }')
    # edges from depends_on
    for cid, comp in cmdb.items():
        for dep in (comp or {}).get("depends_on") or []:
            if dep in cmdb:
                lines.append(f'  {safe(cid)} -> {safe(dep)};')
    lines.append('}')
    dot_src = "\n".join(lines)
    try:
        out = subprocess.run(
            ["dot", "-Tsvg"], input=dot_src, capture_output=True,
            text=True, timeout=10, check=True,
        ).stdout
    except Exception as exc:
        return (f'<p class="topo-note">graphviz failed: {_h(str(exc))}; '
                'falling back to CSS grid.</p>'
                + _render_topology_via_css_grid(s))
    # strip the XML prolog so we can embed inline
    out = re.sub(r'<\?xml[^?]*\?>', '', out)
    out = re.sub(r'<!DOCTYPE[^>]*>', '', out)
    # add our class so CSS can size it
    out = re.sub(r'<svg ', '<svg class="topo-svg" ', out, count=1)
    return out


def _render_topology_via_css_grid(s: dict) -> str:
    """Fallback when Graphviz isn't on PATH — 5 rows of grouped boxes."""
    cmdb = s.get("cmdb") or {}
    topo = _merged_live(cmdb)
    by_tier = _topology_tiers(s)
    rows_html = []
    for t in sorted(by_tier.keys()):
        members = by_tier[t]
        # group by `group` field within the tier
        by_group: dict[str, list[tuple[str, dict]]] = defaultdict(list)
        for cid, comp in members:
            by_group[comp.get("group") or "—"].append((cid, comp))
        groups_html = []
        for grp in sorted(by_group.keys()):
            nodes = []
            for cid, comp in sorted(by_group[grp]):
                st = _node_status(cid, topo)
                fc = "fc" if comp.get("sla_tier") == "family-critical" else ""
                cls = " ".join(filter(None, ["topo-node", st, fc]))
                desc = (comp.get("description") or "")[:140]
                nodes.append(
                    f'<a class="{cls}" href="cmdb.html#{_h(cid)}" '
                    f'title="{_h(desc)}">'
                    f'<span class="s" aria-hidden="true"></span>'
                    f'<span>{_h(cid)}</span></a>'
                )
            groups_html.append(
                f'<div class="topo-group">'
                f'<div class="topo-group-label">{_h(grp)}</div>'
                f'<div class="topo-nodes">{"".join(nodes)}</div>'
                f'</div>'
            )
        rows_html.append(
            f'<div class="topo-row" data-tier="{t}">'
            f'<h3>{t} — {_h(_TIER_LABELS.get(t, str(t)))} '
            f'<span class="tag">{len(members)}</span></h3>'
            f'<div class="topo-groups">{"".join(groups_html)}</div>'
            f'</div>'
        )
        if t < max(by_tier.keys()):
            rows_html.append('<div class="topo-arrow" aria-hidden="true">↓</div>')
    return f'<section class="topo">{"".join(rows_html)}</section>'


def _render_topology_page(s: dict) -> str:
    have_dot = _has_graphviz()
    topo = _load_unifi_topology()
    if have_dot:
        body_inner = _render_topology_via_graphviz(s)
        path_note = "Rendered via Graphviz <code>dot</code>."
    else:
        body_inner = _render_topology_via_css_grid(s)
        path_note = (
            "Graphviz <code>dot</code> not on PATH — rendered as CSS-grid "
            "fallback. Once Heph rebuilds the cluster-health image with "
            "graphviz, this auto-switches to the hierarchical SVG path."
        )
    live_note = (
        f'{len(topo)} live components from <code>/data/unifi-topology.json</code>'
        if topo else
        'No live data yet — <code>/data/unifi-topology.json</code> not present. '
        'Awaiting Iris\'s UniFi adapter (phase 2b). All nodes show as <em>unknown</em>.'
    )
    body = (
        '<section>'
        '<h2>Service topology</h2>'
        f'<p class="topo-note">{path_note} {live_note}</p>'
        f'{body_inner}'
        '<p class="topo-note">Tiers: 0 internet → 1 edge → 2 cluster → '
        '3 stateful → 4 services. Entries without an explicit <code>tier:</code> '
        'field are placed by fallback (type + id prefix); their tier is best-effort '
        'until the phase 2b–e CMDB rollout completes.</p>'
        '</section>'
    )
    return _page("Topology", "topology.html", body, s["now"])


