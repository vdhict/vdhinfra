        ("Argus", "Security engineer (analytical)", "security-engineer",
         "Per-change security review + weekly posture scans."),
        ("Pan", "Pentest engineer (active)", "pentest-engineer",
         "Active probing, fuzzing, exploit attempts — always pre-approved."),
        ("Daedalus", "Design / architecture engineer", "design-engineer",
         "Design docs, ADRs, refactor plans — never touches production."),
        ("Athena", "Research analyst", "it-researcher",
         "Tight sourced research docs on ITSM / SRE / tools / patterns."),
        ("Apollo", "Frontend designer + developer", "frontend-engineer",
         "UI for internal web surfaces; server-rendered HTML+CSS, no SPA."),
    ]
    cards = "".join(
        f'<div class="card"><h3>{_h(name)}</h3>'
        f'<div class="who">{_h(role)} · <code>{_h(agent)}</code></div>'
        f'<p>{_h(desc)}</p></div>'
        for name, role, agent, desc in members
    )
    body = (
        '<section><p class="meta">The household\'s infrastructure team. '
        'You always talk to Atlas; Atlas dispatches.</p>'
        f'<div class="cardlist">{cards}</div></section>'
    )
    return _page("Team", "team.html", body, s["now"])


def _h(s: str) -> str:
    """Tiny HTML escape."""
    return (s or "").replace("&", "&amp;").replace("<", "&lt;").replace(">", "&gt;").replace('"', "&quot;")


def _ts(s: str | None) -> dt.datetime:
    if not s:
        return dt.datetime.fromtimestamp(0, dt.timezone.utc)
    try:
        return dt.datetime.fromisoformat(s.replace("Z", "+00:00"))
    except Exception:
        return dt.datetime.fromtimestamp(0, dt.timezone.utc)


def _resource_known(resource: str) -> bool:
    db = load_cmdb()
    return resource in (db.get("components") or {})


