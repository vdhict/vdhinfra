# ── tiny utils ──────────────────────────────────────────────────────────

def now_iso() -> str:
    return dt.datetime.now(dt.timezone.utc).isoformat(timespec="seconds").replace("+00:00", "Z")


def today_str() -> str:
    return dt.date.today().isoformat()


def next_id(prefix: str, log: Path) -> str:
    """Find next sequential id for today, e.g. chg-2026-05-13-003."""
    today = today_str()
    pat = re.compile(rf"^{re.escape(prefix)}-{re.escape(today)}-(\d+)$")
    n = 0
    if log.exists():
        with log.open() as f:
            for line in f:
                if not line.strip():
                    continue
                try:
                    evt = json.loads(line)
                except json.JSONDecodeError:
                    continue
                m = pat.match(evt.get("chg") or evt.get("inc") or "")
                if m:
                    n = max(n, int(m.group(1)))
    return f"{prefix}-{today}-{n + 1:03d}"


def append_event(log: Path, evt: dict) -> None:
    line = json.dumps(evt, separators=(",", ":"), ensure_ascii=False, sort_keys=True)
    with log.open("a") as f:
        f.write(line + "\n")


def read_events(log: Path) -> list[dict]:
    if not log.exists():
        return []
    out = []
    with log.open() as f:
        for line in f:
            line = line.strip()
            if not line:
                continue
            try:
                out.append(json.loads(line))
            except json.JSONDecodeError as e:
                print(f"warning: bad json in {log.name}: {e}", file=sys.stderr)
    return out


def fold_changes(events: list[dict]) -> dict[str, dict]:
    """Reduce events to current state per chg id."""
    state: dict[str, dict] = {}
    for e in events:
        chg = e.get("chg")
        if not chg:
            continue
        cur = state.setdefault(chg, {
            "id": chg,
            "resource": e.get("resource"),
            "risk": e.get("risk"),
            "actor": e.get("actor"),
            "events": [],
            "status": "requested",
            "summary": None,
            "reason": None,
            "first_ts": e.get("ts"),
            "last_ts": e.get("ts"),
        })
        cur["events"].append(e)
        cur["last_ts"] = e.get("ts") or cur["last_ts"]
        # update headline fields
        if e.get("resource"):
            cur["resource"] = e["resource"]
        if e.get("risk"):
            cur["risk"] = e["risk"]
        payload = e.get("payload") or {}
        if "summary" in payload and not cur["summary"]:
            cur["summary"] = payload["summary"]
        if "reason" in payload and not cur["reason"]:
            cur["reason"] = payload["reason"]
        event = e.get("event")
        if event:
            cur["status"] = event
    return state


def fold_incidents(events: list[dict]) -> dict[str, dict]:
    state: dict[str, dict] = {}
    for e in events:
        inc = e.get("inc")
        if not inc:
            continue
        cur = state.setdefault(inc, {
            "id": inc,
            "severity": e.get("severity"),
            "actor": e.get("actor"),
            "events": [],
            "status": "opened",
            "summary": None,
            "first_ts": e.get("ts"),
            "last_ts": e.get("ts"),
        })
        cur["events"].append(e)
        cur["last_ts"] = e.get("ts") or cur["last_ts"]
        if e.get("severity"):
            cur["severity"] = e["severity"]
        payload = e.get("payload") or {}
        if "summary" in payload and not cur["summary"]:
            cur["summary"] = payload["summary"]
        if e.get("event"):
            cur["status"] = e["event"]
    return state


def load_cmdb() -> dict:
    """Minimal YAML loader for the cmdb (good-enough subset)."""
    if not CMDB.exists():
        return {"components": {}}
    # Pull in pyyaml if available; otherwise tiny parser sufficient for our schema
    try:
        import yaml  # type: ignore
        with CMDB.open() as f:
            return yaml.safe_load(f) or {"components": {}}
    except ImportError:
        return _tiny_yaml_load(CMDB)


def load_freeze() -> dict:
    if not FREEZE.exists():
        return {"freezes": []}
    try:
        import yaml  # type: ignore
        with FREEZE.open() as f:
            return yaml.safe_load(f) or {"freezes": []}
    except ImportError:
        return _tiny_yaml_load(FREEZE)


def _tiny_yaml_load(path: Path) -> dict:
    """Last-resort flat YAML parser for our schema (component map only)."""
    components: dict[str, dict] = {}
    freezes: list[dict] = []
    cur_key = None
    cur_obj: dict | None = None
    section = None
    with path.open() as f:
        for raw in f:
            line = raw.rstrip("\n")
            if not line.strip() or line.lstrip().startswith("#"):
                continue
            indent = len(line) - len(line.lstrip())
            stripped = line.strip()
            if indent == 0 and stripped.endswith(":"):
                section = stripped[:-1]
                continue
            if section == "components" and indent == 2 and stripped.endswith(":"):
                cur_key = stripped[:-1]
                cur_obj = {}
                components[cur_key] = cur_obj
                continue
            if section == "components" and cur_obj is not None and indent == 4 and ":" in stripped:
                k, _, v = stripped.partition(":")
                v = v.strip()
                if v.startswith("[") and v.endswith("]"):
                    inner = v[1:-1].strip()
                    cur_obj[k.strip()] = [x.strip() for x in inner.split(",") if x.strip()]
                else:
                    if v.lower() == "true": cur_obj[k.strip()] = True
                    elif v.lower() == "false": cur_obj[k.strip()] = False
                    else: cur_obj[k.strip()] = v
                continue
    return {"components": components, "freezes": freezes}


# ── ANSI ────────────────────────────────────────────────────────────────

class C:
    BOLD = "\033[1m"; DIM = "\033[2m"; RESET = "\033[0m"
    RED = "\033[31m"; YEL = "\033[33m"; GRN = "\033[32m"; CYAN = "\033[36m"


def risk_color(r: str) -> str:
    return {"low": C.GRN, "medium": C.YEL, "high": C.RED}.get(r or "", "")


def sev_color(s: str) -> str:
    return {"sev3": C.YEL, "sev2": C.RED, "sev1": C.RED + C.BOLD}.get(s or "", "")


# ── commands ────────────────────────────────────────────────────────────

def cmd_status(args):
    chgs = fold_changes(read_events(CHANGES))
    incs = fold_incidents(read_events(INCIDENTS))
    open_chgs = [c for c in chgs.values() if c["status"] not in {"closed", "rejected", "rolled_back"}]
    open_incs = [i for i in incs.values() if i["status"] != "closed"]
    today = today_str()
    today_chgs = [c for c in chgs.values() if (c["first_ts"] or "").startswith(today)]
    today_incs = [i for i in incs.values() if (i["first_ts"] or "").startswith(today)]
    locks = sorted([p.name for p in LOCK_DIR.iterdir() if p.is_file() and p.name != ".gitkeep"])
    freezes = load_freeze().get("freezes") or []

    print(f"{C.BOLD}ops status — {today}{C.RESET}")
    print()
    print(f"{C.BOLD}OPEN CHANGES ({len(open_chgs)}){C.RESET}")
    for c in sorted(open_chgs, key=lambda x: x["last_ts"] or "")[-20:]:
        rc = risk_color(c["risk"])
        print(f"  {c['id']}  {rc}{(c['risk'] or '?'):<6}{C.RESET}  {c['status']:<10}  {c['resource'] or '?':<35}  {(c['summary'] or '')[:60]}")
    if not open_chgs:
        print(f"  {C.DIM}none{C.RESET}")
    print()

    print(f"{C.BOLD}OPEN INCIDENTS ({len(open_incs)}){C.RESET}")
    for i in sorted(open_incs, key=lambda x: x["last_ts"] or ""):
        sc = sev_color(i["severity"])
        print(f"  {i['id']}  {sc}{(i['severity'] or '?'):<5}{C.RESET}  {i['status']:<12}  {(i['summary'] or '')[:80]}")
    if not open_incs:
        print(f"  {C.DIM}none{C.RESET}")
    print()

    print(f"{C.BOLD}ACTIVE LOCKS ({len(locks)}){C.RESET}")
    for l in locks:
        body = (LOCK_DIR / l).read_text().strip()
        print(f"  {l}  {C.DIM}{body}{C.RESET}")
    if not locks:
        print(f"  {C.DIM}none{C.RESET}")
    print()

    print(f"{C.BOLD}TODAY{C.RESET}  changes={len(today_chgs)}  incidents={len(today_incs)}")
    if freezes:
        active = [f for f in freezes if _freeze_active(f)]
        if active:
            print(f"  {C.RED}freeze active:{C.RESET} {', '.join(f['name'] for f in active)}")


def _freeze_active(f: dict) -> bool:
    try:
        s = dt.datetime.fromisoformat((f.get("starts") or "").replace("Z", "+00:00"))
        e = dt.datetime.fromisoformat((f.get("ends") or "").replace("Z", "+00:00"))
        return s <= dt.datetime.now(dt.timezone.utc) <= e
    except Exception:
        return False


def cmd_change_new(args):
    chg = next_id("chg", CHANGES)
    if args.risk not in RISK_TIERS:
        sys.exit(f"risk must be one of: {sorted(RISK_TIERS)}")
    if args.actor not in ENGINEERS:
        sys.exit(f"actor must be one of: {sorted(ENGINEERS)}")
    if not _resource_known(args.resource):
        print(f"warning: resource '{args.resource}' is not in cmdb; consider adding it", file=sys.stderr)
    evt = {
        "chg": chg,
        "ts": now_iso(),
        "event": "requested",
        "actor": args.actor,
        "resource": args.resource,
        "risk": args.risk,
        "payload": {
            "summary": args.summary or "",
            "reason": args.reason or "",
            "requested_by": args.requested_by or args.actor,
        },
    }
    append_event(CHANGES, evt)
    print(chg)


def cmd_change_event(args):
    if args.event not in CHANGE_EVENTS:
        sys.exit(f"event must be one of: {sorted(CHANGE_EVENTS)}")
    if args.actor and args.actor not in ENGINEERS:
        sys.exit(f"actor must be one of: {sorted(ENGINEERS)}")
    payload = json.loads(args.payload_json) if args.payload_json else {}
    evt = {
        "chg": args.chg,
        "ts": now_iso(),
        "event": args.event,
        "actor": args.actor or "infra-ops",
        "payload": payload,
    }
    append_event(CHANGES, evt)
    print(f"appended {args.event} to {args.chg}")


