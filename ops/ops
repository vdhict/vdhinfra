def cmd_digest(args):
    days = args.days or 1
    cutoff = dt.datetime.now(dt.timezone.utc) - dt.timedelta(days=days)
    chgs = fold_changes(read_events(CHANGES))
    incs = fold_incidents(read_events(INCIDENTS))
    recent_chgs = [c for c in chgs.values() if _ts(c.get("last_ts")) >= cutoff]
    recent_incs = [i for i in incs.values() if _ts(i.get("last_ts")) >= cutoff]
    by_status: dict[str, int] = defaultdict(int)
    by_actor: dict[str, int] = defaultdict(int)
    for c in recent_chgs:
        by_status[c["status"]] += 1
        by_actor[c["actor"] or "?"] += 1
    print(f"{C.BOLD}Digest — last {days} day(s){C.RESET}")
    print(f"changes: {len(recent_chgs)}   incidents: {len(recent_incs)}")
    if by_status:
        print("  by status:", ", ".join(f"{k}={v}" for k, v in sorted(by_status.items())))
    if by_actor:
        print("  by actor:", ", ".join(f"{k}={v}" for k, v in sorted(by_actor.items())))
    print()
    if recent_chgs:
        print(f"{C.BOLD}Changes:{C.RESET}")
        for c in sorted(recent_chgs, key=lambda x: x["last_ts"] or "", reverse=True):
            rc = risk_color(c["risk"])
            print(f"  {c['id']}  {rc}{(c['risk'] or '?'):<6}{C.RESET}  {c['status']:<10}  {c['resource'] or '?':<35}  {(c['summary'] or '')[:60]}")
    if recent_incs:
        print(f"{C.BOLD}Incidents:{C.RESET}")
        for i in sorted(recent_incs, key=lambda x: x["last_ts"] or "", reverse=True):
            sc = sev_color(i["severity"])
            print(f"  {i['id']}  {sc}{(i['severity'] or '?'):<5}{C.RESET}  {i['status']:<12}  {(i['summary'] or '')[:80]}")


def cmd_dashboard(args):
    """Render the ops portal v2.

    --html PATH writes the portal. PATH semantics:
      - directory (or path not ending in .html): write the multi-page portal
        (index.html, changes.html, incidents.html, cmdb.html, risks.html,
        team.html). The default mode.
      - ends in .html: write the legacy single-page mega-dashboard to that
        file (back-compat for any external caller still expecting one file).
    If --html is omitted, the index page is written to stdout.

    Lean by design: server-rendered HTML+CSS, no JS, no external assets,
    target <50 kB per page (excluding the data payload itself). System fonts
    only. color-scheme: light dark for automatic dark mode.
    """
    state = _gather_portal_state()
    if not args.html:
        sys.stdout.write(_render_index(state))
        return

    out = Path(args.html)
    # Single-file mode for back-compat: arg ends in .html and the path isn't
    # an existing directory.
    if out.suffix == ".html" and not out.is_dir():
        out.parent.mkdir(parents=True, exist_ok=True)
        page = _render_index(state)
        out.write_text(page)
        print(f"wrote {out} ({len(page)} bytes)")
        return

    # Directory mode — the v2 portal.
    out.mkdir(parents=True, exist_ok=True)
    pages = {
        "index.html": _render_index(state),
        "changes.html": _render_changes(state),
        "incidents.html": _render_incidents(state),
        "cmdb.html": _render_cmdb(state),
        "risks.html": _render_risks(state),
        "team.html": _render_team(state),
    }
    total = 0
    for name, body in pages.items():
        p = out / name
        p.write_text(body)
        n = len(body)
        total += n
        print(f"wrote {p} ({n} bytes)")
    print(f"portal total {total} bytes across {len(pages)} pages")


