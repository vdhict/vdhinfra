def _gather_portal_state() -> dict:
    chgs = fold_changes(read_events(CHANGES))
    incs = fold_incidents(read_events(INCIDENTS))
    cmdb = load_cmdb().get("components", {})
    freezes = load_freeze().get("freezes") or []
    risks = _load_risks().get("risks") or []
    locks = sorted([p.name for p in LOCK_DIR.iterdir()
                    if p.is_file() and p.name != ".gitkeep"])
    now = dt.datetime.now(dt.timezone.utc)
    cutoff_7d = now - dt.timedelta(days=7)
    open_chgs = [c for c in chgs.values()
                 if c["status"] not in {"closed", "rejected", "rolled_back"}]
    open_incs = [i for i in incs.values() if i["status"] != "closed"]
    recent_chgs = [c for c in chgs.values() if _ts(c.get("last_ts")) >= cutoff_7d]
    recent_incs = [i for i in incs.values() if _ts(i.get("last_ts")) >= cutoff_7d]
    return {
        "now": now,
        "chgs": chgs, "incs": incs,
        "open_chgs": open_chgs, "open_incs": open_incs,
        "recent_chgs": recent_chgs, "recent_incs": recent_incs,
        "cmdb": cmdb, "freezes": freezes, "risks": risks, "locks": locks,
        "active_freezes": [f for f in freezes if _freeze_active(f)],
    }


def _load_risks() -> dict:
    path = OPS_DIR / "accepted_risks.yaml"
    if not path.exists():
        return {"risks": []}
    try:
        import yaml  # type: ignore
        with path.open() as f:
            return yaml.safe_load(f) or {"risks": []}
    except ImportError:
        # Tiny fallback for our exact schema.
        risks: list[dict] = []
        cur: dict | None = None
        with path.open() as f:
            for raw in f:
                line = raw.rstrip("\n")
                s = line.strip()
                if not s or s.startswith("#"):
                    continue
                if line.startswith("  - "):
                    if cur is not None:
                        risks.append(cur)
                    cur = {}
                    k, _, v = s[2:].partition(":")
                    if v.strip():
                        cur[k.strip()] = v.strip().strip('"')
                elif line.startswith("    ") and cur is not None and ":" in s:
                    k, _, v = s.partition(":")
                    cur[k.strip()] = v.strip().strip('"')
        if cur is not None:
            risks.append(cur)
        return {"risks": risks}


def _page(title: str, current: str, body: str, gen_ts: dt.datetime,
          extra_meta: str = "") -> str:
    # Local-portal tabs first (relative paths). Then external deep-links
    # to Grafana for metrics dashboards + Loki searches — open in new tab.
    tabs = [
        ("index.html", "Overview", False),
        ("topology.html", "Topology", False),
        ("changes.html", "Changes", False),
        ("incidents.html", "Incidents", False),
        ("cmdb.html", "CMDB", False),
        ("risks.html", "Risks", False),
        ("team.html", "Team", False),
        ("reports.html", "Health reports", False),
        ("https://grafana.bluejungle.net/", "Grafana ↗", True),
        ("https://grafana.bluejungle.net/explore?left=%7B%22datasource%22%3A%22Loki%22%7D", "Logs ↗", True),
    ]
    parts = []
    for href, label, external in tabs:
        cur_cls = ' class="cur"' if href == current else ''
        target_attr = ' target="_blank" rel="noopener"' if external else ''
        parts.append(f'<a href="{href}"{cur_cls}{target_attr}>{_h(label)}</a>')
    nav = "".join(parts)
    return (
        '<!doctype html>\n'
        '<html lang="en"><head><meta charset="utf-8">'
        '<meta name="viewport" content="width=device-width,initial-scale=1">'
        '<meta http-equiv="refresh" content="600">'
        f'<title>{_h(title)} · vdhinfra ops</title>'
        f'<style>{_PORTAL_CSS}</style></head><body>'
        '<header><h1>vdhinfra ops portal</h1>'
        f'<nav class="tabs">{nav}</nav>'
        f'<div class="meta">Generated {gen_ts.isoformat(timespec="seconds")} · '
        'auto-refresh 10m'
        f'{(" · " + extra_meta) if extra_meta else ""}'
        '</div></header>'
        f'{body}'
        '<footer>Event-sourced from <code>ops/</code> in <code>vdhict/vdhinfra</code>. '
        'CLI: <code>./ops/ops status</code>. '
        'Read-only — writes happen via the CLI only.</footer>'
        '</body></html>\n'
    )


def _chg_row(c: dict, with_resource: bool = True) -> str:
    risk = c.get("risk") or "?"
    cells = [
        f'<td><a href="changes.html#{_h(c["id"])}">{_h(c["id"])}</a></td>',
        f'<td class="pill">{_h(risk)}</td>',
        f'<td>{_h(c["status"])}</td>',
    ]
    if with_resource:
        cells.append(f'<td>{_h(c.get("resource") or "?")}</td>')
    cells.append(f'<td>{_h((c.get("summary") or ""))}</td>')
    cells.append(f'<td class="ts">{_h((c.get("last_ts") or "")[:16].replace("T"," "))}</td>')
    return f'<tr class="r-{_h(risk)}">{"".join(cells)}</tr>'


def _inc_row(i: dict) -> str:
    sev = i.get("severity") or "?"
    return (
        f'<tr class="s-{_h(sev)}">'
        f'<td><a href="incidents.html#{_h(i["id"])}">{_h(i["id"])}</a></td>'
        f'<td class="pill">{_h(sev)}</td>'
        f'<td>{_h(i["status"])}</td>'
        f'<td>{_h(i.get("summary") or "")}</td>'
        f'<td class="ts">{_h((i.get("last_ts") or "")[:16].replace("T"," "))}</td>'
        '</tr>'
    )


def _kpi(value, label, alert: bool = False) -> str:
    cls = "kpi alert" if alert else "kpi"
    return f'<div class="{cls}"><div class="v">{_h(str(value))}</div><div class="l">{_h(label)}</div></div>'


def _render_index(s: dict) -> str:
    risk_counts = {r: sum(1 for c in s["recent_chgs"] if c.get("risk") == r)
                   for r in ("low", "medium", "high")}
    sev_counts = {sv: sum(1 for i in s["open_incs"] if i.get("severity") == sv)
                  for sv in ("sev1", "sev2", "sev3")}
    open_chgs_sorted = sorted(s["open_chgs"],
                              key=lambda x: x.get("last_ts") or "", reverse=True)
    open_incs_sorted = sorted(s["open_incs"],
                              key=lambda x: x.get("last_ts") or "", reverse=True)

    banners = []
    if s["active_freezes"]:
        items = "".join(
            f'<li><strong>{_h(f.get("name",""))}</strong> — '
            f'ends {_h(f.get("ends","?"))} · blocks {_h(", ".join(f.get("blocks") or []))}: '
            f'{_h(f.get("reason",""))}</li>'
            for f in s["active_freezes"])
        banners.append(
            f'<div class="banner"><h3>Change-freeze active</h3><ul>{items}</ul></div>')
    if sev_counts["sev1"] or sev_counts["sev2"]:
        banners.append(
            '<div class="banner red"><h3>High-severity incident open</h3>'
            f'<ul><li>{sev_counts["sev1"]} sev1 · {sev_counts["sev2"]} sev2 — see '
            '<a href="incidents.html">incidents</a></li></ul></div>')
    banner_block = "".join(banners)

    kpis = (
        f'<section class="kpis">'
        + _kpi(len(s["open_chgs"]), "open changes")
        + _kpi(len(s["open_incs"]), "open incidents", alert=bool(sev_counts["sev1"] or sev_counts["sev2"]))
        + _kpi(len(s["active_freezes"]), "active freezes",
               alert=bool(s["active_freezes"]))
        + _kpi(len(s["locks"]), "active locks")
        + _kpi(f"{risk_counts['low']}/{risk_counts['medium']}/{risk_counts['high']}",
               "risk 7d (L/M/H)")
        + _kpi(len(s["cmdb"]), "cmdb components")
        + _kpi(len(s["risks"]), "accepted risks")
        + '</section>'
    )

    chg_rows = ("".join(_chg_row(c) for c in open_chgs_sorted[:15])
                or '<tr><td colspan="6" class="empty">no open changes</td></tr>')
    inc_rows = ("".join(_inc_row(i) for i in open_incs_sorted[:10])
                or '<tr><td colspan="5" class="empty">no open incidents</td></tr>')

    lock_block = ""
    if s["locks"]:
        rows = "".join(
            f'<tr><td><code>{_h(l)}</code></td>'
            f'<td>{_h((LOCK_DIR / l).read_text().strip())}</td></tr>'
            for l in s["locks"])
        lock_block = (
            '<section><h2>Active locks</h2><table>'
            '<thead><tr><th>resource</th><th>holder</th></tr></thead>'
            f'<tbody>{rows}</tbody></table></section>')

    pill_block = _render_family_pill(s)
    body = (
        f'{pill_block}{banner_block}{kpis}'
        '<section><h2>Open changes <span class="tag">'
        f'{len(s["open_chgs"])}</span></h2><table>'
        '<thead><tr><th>id</th><th>risk</th><th>status</th>'
        '<th>resource</th><th>summary</th><th>updated</th></tr></thead>'
        f'<tbody>{chg_rows}</tbody></table>'
        '<p class="meta"><a href="changes.html">All changes →</a></p></section>'
        '<section><h2>Open incidents <span class="tag">'
        f'{len(s["open_incs"])}</span></h2><table>'
        '<thead><tr><th>id</th><th>sev</th><th>status</th>'
        '<th>summary</th><th>updated</th></tr></thead>'
        f'<tbody>{inc_rows}</tbody></table>'
        '<p class="meta"><a href="incidents.html">All incidents →</a></p></section>'
        f'{lock_block}'
    )
    return _page("Overview", "index.html", body, s["now"])


def _event_line(e: dict) -> str:
    ts = (e.get("ts") or "")[:19].replace("T", " ")
    pl = e.get("payload") or {}
    pl_short = ", ".join(f"{k}={_h(_short(v))}" for k, v in pl.items()) if pl else ""
    return (f'<div class="evt"><code>{_h(ts)}</code> '
            f'<strong>{_h(e.get("event",""))}</strong> '
            f'· {_h(e.get("actor",""))} '
            f'{("· " + pl_short) if pl_short else ""}</div>')


def _short(v) -> str:
    if isinstance(v, list):
        return ", ".join(str(x) for x in v)
    s = str(v)
    return s if len(s) <= 120 else s[:117] + "…"


def _render_changes(s: dict) -> str:
    items = sorted(s["chgs"].values(),
                   key=lambda x: x.get("last_ts") or "", reverse=True)
    open_count = len(s["open_chgs"])
    rows = []
    for c in items:
        rid = _h(c["id"])
        risk = c.get("risk") or "?"
        evts = "".join(_event_line(e) for e in c.get("events", []))
        rows.append(
            f'<tr class="r-{_h(risk)}" id="{rid}">'
            f'<td><code>{rid}</code></td>'
            f'<td class="pill">{_h(risk)}</td>'
            f'<td>{_h(c["status"])}</td>'
            f'<td>{_h(c.get("resource") or "?")}</td>'
            f'<td>{_h(c.get("summary") or "")}'
            f'<details><summary>{len(c.get("events", []))} events</summary>{evts}</details></td>'
            f'<td class="ts">{_h((c.get("last_ts") or "")[:16].replace("T"," "))}</td>'
            '</tr>'
        )
    body_rows = "".join(rows) or '<tr><td colspan="6" class="empty">no changes</td></tr>'
    body = (
        '<section><h2>All changes '
        f'<span class="tag">{len(items)}</span> '
        f'<span class="tag">{open_count} open</span></h2>'
        '<table>'
        '<thead><tr><th>id</th><th>risk</th><th>status</th>'
        '<th>resource</th><th>summary · events</th><th>updated</th></tr></thead>'
        f'<tbody>{body_rows}</tbody></table></section>'
    )
    return _page("Changes", "changes.html", body, s["now"])


