def cmd_lock_acquire(args):
    p = LOCK_DIR / args.resource.replace("/", "_")
    if p.exists():
        body = p.read_text().strip()
        sys.exit(f"lock held: {body}")
    p.write_text(f"{args.by} ts={now_iso()} reason={args.reason}\n")
    print(f"acquired {p.name}")


def cmd_lock_release(args):
    p = LOCK_DIR / args.resource.replace("/", "_")
    if p.exists():
        p.unlink()
        print(f"released {p.name}")
    else:
        sys.exit(f"no lock held on {args.resource}")


def cmd_lock_list(args):
    for p in sorted(LOCK_DIR.iterdir()):
        if p.is_file() and p.name != ".gitkeep":
            print(f"{p.name}  {p.read_text().strip()}")


